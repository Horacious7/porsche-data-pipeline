AZURE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=datalakeporscheho;AccountKey=REPLACE_WITH_YOUR_KEY;EndpointSuffix=core.windows.net
PARK_JARS_PACKAGES="org.apache.hadoop:hadoop-azure:3.3.2,com.microsoft.azure:azure-storage:8.6.6,org.postgresql:postgresql:42.6.0"
PG_HOST="YOUR-SERVER.postgres.database.azure.com"
PG_USER="YOUR-USERNAME"
PG_PORT="5432"
PG_DATABASE="postgres"
PG_PASSWORD="YOUR-PASSWORD"